<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/header_merah"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profil"
            android:textColor="#FFD700"
            android:textSize="20sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <ScrollView
        android:id="@+id/rnl3r8vtlwd"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/rv45kpow9x1r"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:background="@drawable/cr20bffffff"
                android:paddingTop="21dp"
                android:layout_marginBottom="9dp"
                android:layout_marginHorizontal="21dp"
                android:elevation="30dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/rwtuauhi6bcr"
                    android:textColor="#9B0A0E"
                    android:textSize="20sp"
                    android:layout_marginBottom="45dp"
                    android:layout_marginTop="21dp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Metode Pembayaran"/>

                <LinearLayout
                    android:id="@+id/rcol6fu8bnis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="24dp"
                    android:layout_marginHorizontal="21dp"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/rjccj14873"
                        android:layout_width="55dp"
                        android:layout_height="54dp"
                        android:layout_marginEnd="15dp"
                        android:src="@drawable/iconemoney"
                        android:scaleType="fitXY"/>

                    <TextView
                        android:id="@+id/r9t49n6s14j"
                        android:textColor="#1A1A1A"
                        android:textSize="14sp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Hubungkan E-Wallet"/>

                    <ImageView
                        android:id="@+id/rmwpskrixvof"
                        android:layout_width="30dp"
                        android:layout_height="36dp"
                        android:src="@drawable/blackarrow"
                        android:scaleType="fitXY"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/r0hxnh7jb4nzq"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="24dp"
                    android:layout_marginHorizontal="23dp"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/r78tkmn6eupg"
                        android:layout_width="55dp"
                        android:layout_height="54dp"
                        android:layout_marginEnd="13dp"
                        android:src="@drawable/iconmbanking"
                        android:scaleType="fitXY"/>

                    <TextView
                        android:id="@+id/r9iteg1jxoh4"
                        android:textColor="#1A1A1A"
                        android:textSize="14sp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Hubungkan M-Banking"/>

                    <ImageView
                        android:id="@+id/rrvwyr63ho"
                        android:layout_width="30dp"
                        android:layout_height="36dp"
                        android:src="@drawable/blackarrow"
                        android:scaleType="fitXY"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/rksifqkrjer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="270dp"
                    android:layout_marginHorizontal="23dp"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/r041ted9f31le"
                        android:layout_width="55dp"
                        android:layout_height="54dp"
                        android:layout_marginEnd="15dp"
                        android:src="@drawable/iconqris"
                        android:scaleType="fitXY"/>

                    <TextView
                        android:id="@+id/rg9fporu0q4"
                        android:textColor="#1A1A1A"
                        android:textSize="14sp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Hubungkan QRIS"/>

                    <ImageView
                        android:id="@+id/rrcrl2auwu1j"
                        android:layout_width="30dp"
                        android:layout_height="36dp"
                        android:src="@drawable/blackarrow"
                        android:scaleType="fitXY"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/rv9f1jiwocja"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/cr20b9b0a0e"
                    android:paddingVertical="19dp"
                    android:paddingHorizontal="52dp"
                    android:layout_marginBottom="34dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/r6uuwgn7u1sw"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Kembali"/>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>