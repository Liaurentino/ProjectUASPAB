<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#FFFFFF" android:orientation="vertical">
    <!--  Header bawaan  -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:background="@drawable/br20bl20b9b0a0e" android:paddingVertical="20dp" android:paddingHorizontal="13dp" android:orientation="horizontal">
        <ImageView android:id="@+id/ruujtneij4rr" android:layout_width="30dp" android:layout_height="30dp" android:src="@drawable/backarrow" android:scaleType="fitXY"/>
        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
        <TextView android:textColor="#FFD700" android:textSize="17sp" android:layout_height="wrap_content" android:layout_width="wrap_content" android:text="Checkout"/>
        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
        <LinearLayout android:layout_width="30dp" android:layout_height="30dp" android:orientation="vertical"/>
    </LinearLayout>
    <!--  Konten Tengah  -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
        <ImageView android:layout_width="280dp" android:layout_height="350dp" android:src="@drawable/popupkonfirmasi" android:scaleType="fitCenter"/>
    </LinearLayout>
    <!--  Tombol bawaan  -->
    <LinearLayout android:id="@+id/btnKonfirmasi" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_horizontal" android:background="@drawable/cr20b9b0a0e" android:paddingVertical="18dp" android:layout_marginHorizontal="31dp" android:layout_marginBottom="30dp" android:clickable="true" android:focusable="true" android:orientation="vertical">
        <TextView android:textColor="#FFD700" android:textSize="17sp" android:layout_height="wrap_content" android:layout_width="wrap_content" android:text="KEMBALI"/>
    </LinearLayout>
</LinearLayout>