<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/rundefined_rl_rl"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        >
        <ImageView
            android:id="@+id/rundefined"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@android:drawable/star_big_on"
            android:scaleType="fitXY"
            />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">
            <ScrollView
                android:id="@+id/r5xcgk34ei29"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingTop="11dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">
                    <LinearLayout
                        android:id="@+id/rfxw6m4of92g"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="190dp"
                        android:orientation="horizontal">
                        <LinearLayout
                            android:id="@+id/r5dgjj1lwdo5"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center_horizontal"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/rra7hbvks9dn"
                                android:textColor="#FFFFFF"
                                android:textSize="17sp"
                                android:layout_height="wrap_content"
                                android:layout_width="wrap_content"
                                android:text="9:41"
                                />
                        </LinearLayout>
                        <LinearLayout
                            android:id="@+id/rr2moev14x7b"
                            android:layout_width="0dp"
                            android:layout_height="10dp"
                            android:layout_weight="1"
                            android:orientation="vertical">
                        </LinearLayout>
                        <ImageView
                            android:id="@+id/rtzm95aptlzk"
                            android:layout_width="0dp"
                            android:layout_height="13dp"
                            android:layout_weight="1"
                            android:src="@android:drawable/star_big_on"
                            android:scaleType="fitXY"
                            />
                    </LinearLayout>
                    <ImageView
                        android:id="@+id/r7t1cmkza0w6"
                        android:layout_width="match_parent"
                        android:layout_height="148dp"
                        android:layout_marginBottom="142dp"
                        android:layout_marginStart="21dp"
                        android:layout_marginEnd="35dp"
                        android:src="@android:drawable/star_big_on"
                        android:scaleType="fitXY"
                        />
                    <LinearLayout
                        android:id="@+id/ra6dtawnrtft"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/tl30tr30b9b0a0e"
                        android:paddingVertical="76dp"
                        android:orientation="vertical">
                        <LinearLayout
                            android:id="@+id/rxigxg1euy9i"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:background="@drawable/cr20bffffff"
                            android:paddingVertical="11dp"
                            android:layout_marginBottom="39dp"
                            android:layout_marginHorizontal="20dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/rwkbz2zrhcna"
                                android:textColor="#FFD700"
                                android:textSize="26sp"
                                android:textStyle="bold"
                                android:layout_height="wrap_content"
                                android:layout_width="wrap_content"
                                android:text="Sign In"
                                />
                        </LinearLayout>
                        <LinearLayout
                            android:id="@+id/rsewrkiggy3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:background="@drawable/cr20bffd700"
                            android:paddingVertical="11dp"
                            android:layout_marginHorizontal="21dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/rvuz2q5sr1u"
                                android:textColor="#F2F2F2"
                                android:textSize="26sp"
                                android:textStyle="bold"
                                android:layout_height="wrap_content"
                                android:layout_width="wrap_content"
                                android:text="Sign Up"
                                />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </ScrollView>
        </LinearLayout>
    </RelativeLayout>
</LinearLayout>
