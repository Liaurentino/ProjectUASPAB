<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/header_merah"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Beranda"
            android:textColor="#FFD700"
            android:textSize="20sp"
            android:textStyle="bold" />


    </LinearLayout>

    <ScrollView
        android:id="@+id/rm8toolh7gzj"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:clipChildren="false"
        android:clipToPadding="false">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/rc9c2mmtl7m"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:layout_marginHorizontal="16dp"
                android:orientation="horizontal">
                <ImageView
                    android:id="@+id/rozhjjxom35a"
                    android:layout_width="18dp"
                    android:layout_height="25dp"
                    android:layout_marginTop="15dp"
                    android:layout_marginEnd="9dp"
                    android:scaleType="fitXY"
                    android:src="@drawable/locationmark"/>
                <LinearLayout
                    android:id="@+id/r4vx097w6f3j"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="9dp"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/r10iba45ggezh"
                        android:textColor="#717171"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Lokasi:"/>
                    <TextView
                        android:id="@+id/rinl6pw47y3m"
                        android:textColor="#1A1A1A"
                        android:textSize="16sp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Jl. Thamrin, Jakarta Pusat"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"/>
                <ImageView
                    android:id="@+id/r1gs888lu61"
                    android:layout_width="39dp"
                    android:layout_height="39dp"
                    android:src="@drawable/profilekanan"
                    android:scaleType="fitXY"/>
            </LinearLayout>

            <!-- Search Bar -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp">
                <LinearLayout
                    android:paddingVertical="9dp"
                    android:paddingHorizontal="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <LinearLayout
                        android:id="@+id/rqs7cnjk1ru"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:background="@drawable/sd9d9d9sw1cr10"
                        android:paddingHorizontal="8dp"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔍"
                            android:textColor="#3C3C43"
                            android:textSize="17sp"
                            android:layout_marginEnd="6dp"/>
                        <EditText
                            android:inputType="text"
                            android:hint="Cari makanan atau restoran favoritmu"
                            android:background="@null"
                            android:id="@+id/rvgyx4lwrfgi"
                            android:textColor="#3C3C43"
                            android:textSize="14sp"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:paddingVertical="7dp"/>
                    </LinearLayout>
                </LinearLayout>
            </RelativeLayout>

            <!-- Menu Kategori -->
            <LinearLayout
                android:id="@+id/r99h7kot9kl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="15dp"
                android:layout_marginHorizontal="8dp"
                android:orientation="horizontal"
                android:gravity="center">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:id="@+id/rqbcr5wbcayk"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:scaleType="fitXY"
                        android:src="@drawable/iconsate"/>
                    <TextView
                        android:id="@+id/r4eulso4vd1i"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="#1A1A1A"
                        android:textSize="12sp"
                        android:text="Sate"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:id="@+id/r18zyhj3yeeb"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:scaleType="fitXY"
                        android:src="@drawable/iconnasigoreng"/>
                    <TextView
                        android:id="@+id/rc4t9o1snpbb"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="#1A1A1A"
                        android:textSize="12sp"
                        android:text="Nasi Goreng"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:id="@+id/re1gk1otxzec"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:scaleType="fitXY"
                        android:src="@drawable/iconayamgoreng"/>
                    <TextView
                        android:id="@+id/rs5glxgaqra"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="#1A1A1A"
                        android:textSize="12sp"
                        android:text="Ayam Goreng"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:id="@+id/rvpg4r7nxnv"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:scaleType="fitXY"
                        android:src="@drawable/iconminuman"/>
                    <TextView
                        android:id="@+id/rae2tcxem6d6"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="#1A1A1A"
                        android:textSize="12sp"
                        android:text="Minuman"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Banner -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="13dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="6dp"
                    android:paddingHorizontal="27dp"
                    android:orientation="vertical">
                    <ImageView
                        android:id="@+id/rab7xkxt74u"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        android:src="@drawable/sate"
                        android:scaleType="fitXY"/>
                </LinearLayout>
            </RelativeLayout>

            <!-- Dots -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:layout_marginBottom="5dp"
                android:orientation="vertical">
                <ImageView
                    android:id="@+id/r18z2jc0hfdq"
                    android:layout_width="24dp"
                    android:layout_height="6dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/more"/>
            </LinearLayout>

            <!-- Restoran Terdekat -->
            <TextView
                android:id="@+id/rzt58hws3tv"
                android:textColor="#1A1A1A"
                android:textSize="20sp"
                android:layout_marginBottom="11dp"
                android:layout_marginStart="12dp"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:text="Restoran Terdekat"/>

            <!-- Card Warung Sate Senayan -->
            <LinearLayout
                android:id="@+id/rvd63t84q4i8"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:background="@drawable/sf2f2f2sw1cr15bffffff"
                android:paddingVertical="10dp"
                android:layout_marginBottom="14dp"
                android:layout_marginHorizontal="15dp"
                android:elevation="4dp"
                android:orientation="horizontal">
                <ImageView
                    android:id="@+id/r3rh15zkb0u"
                    android:layout_width="91dp"
                    android:layout_height="69dp"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="7dp"
                    android:src="@drawable/warungsatesenayan"
                    android:scaleType="fitXY"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/rqu4nbbmj62q"
                        android:textColor="#1A1A1A"
                        android:textSize="16sp"
                        android:layout_marginBottom="3dp"
                        android:layout_marginStart="14dp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Warung Sate Senayan"/>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="1dp"
                        android:orientation="horizontal">
                        <ImageView
                            android:id="@+id/r5jrlpgqx33h"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:scaleType="fitXY"
                            android:src="@drawable/bintang"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="4,9"
                            android:textColor="#1A1A1A"
                            android:textSize="10sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="15 menit pengantaran"
                            android:textColor="#1A1A1A"
                            android:textSize="10sp"/>
                    </LinearLayout>
                    <TextView
                        android:textColor="#1A1A1A"
                        android:textSize="10sp"
                        android:layout_marginBottom="6dp"
                        android:layout_marginStart="5dp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Rp. 12,000 Ongkir"/>
                    <TextView
                        android:textColor="#1A1A1A"
                        android:textSize="10sp"
                        android:layout_marginStart="5dp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Sate Ayam, Gado-gado"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Card Nasi Goreng Pak Kumis -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:background="@drawable/sf2f2f2sw1cr15bffffff"
                android:paddingVertical="10dp"
                android:layout_marginBottom="14dp"
                android:layout_marginHorizontal="15dp"
                android:elevation="4dp"
                android:orientation="horizontal">
                <ImageView
                    android:id="@+id/rmvou7rwndfa"
                    android:layout_width="91dp"
                    android:layout_height="69dp"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="7dp"
                    android:src="@drawable/nasigorengpakkumis"
                    android:scaleType="fitXY"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/rat17memgy78"
                        android:textColor="#1A1A1A"
                        android:textSize="16sp"
                        android:layout_marginBottom="3dp"
                        android:layout_marginStart="14dp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Nasi Goreng Pak Kumis"/>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="1dp"
                        android:orientation="horizontal">
                        <ImageView
                            android:id="@+id/ryse3oc95qmr"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:scaleType="fitXY"
                            android:src="@drawable/bintang"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="4,8"
                            android:textColor="#1A1A1A"
                            android:textSize="10sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="20 menit pengantaran"
                            android:textColor="#1A1A1A"
                            android:textSize="10sp"/>
                    </LinearLayout>
                    <TextView
                        android:textColor="#1A1A1A"
                        android:textSize="10sp"
                        android:layout_marginBottom="6dp"
                        android:layout_marginStart="5dp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Rp. 10,000 Ongkir"/>
                    <TextView
                        android:textColor="#1A1A1A"
                        android:textSize="10sp"
                        android:layout_marginStart="5dp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Nasi Goreng, Mie Goreng"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>