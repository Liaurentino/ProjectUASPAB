<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/header_merah"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Menu"
            android:textColor="#FFD700"
            android:textSize="20sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <ScrollView
        android:id="@+id/rrhihqssek9"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#ffffff">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/rt8m92275aj"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp"
                android:layout_marginStart="9dp"
                android:layout_marginEnd="36dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/rmdr4vjmjhh"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_marginEnd="13dp"
                    android:src="@drawable/profilekanan"
                    android:scaleType="fitXY" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="13dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/r3tii9i8wowm"
                        android:textColor="#1A1A1A"
                        android:textSize="17sp"
                        android:layout_marginBottom="8dp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Hello, Yanuar" />

                    <TextView
                        android:id="@+id/rhscvmhpp9bs"
                        android:textColor="#717171"
                        android:textSize="14sp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Hari Ini Anda Mau Makan Apa?" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/re18opwja89m"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="27dp"
                android:layout_marginHorizontal="11dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:background="@drawable/s717171sw1cr5bf2f2f2"
                    android:paddingHorizontal="8dp"
                    android:layout_marginEnd="7dp"
                    android:elevation="10dp"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="7dp"
                        android:src="@android:drawable/ic_menu_search"
                        android:scaleType="fitXY" />

                    <EditText
                        android:inputType="text"
                        android:hint="Cari"
                        android:background="@null"
                        android:id="@+id/r5w9dzyi51kl"
                        android:textColor="#C2C2C2"
                        android:textSize="16sp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:paddingVertical="9dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/s717171sw1cr5bf2f2f2"
                    android:padding="4dp"
                    android:elevation="4dp"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@android:drawable/ic_menu_sort_by_size"
                        android:scaleType="fitXY" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="11dp"
                android:layout_marginHorizontal="10dp"
                android:orientation="horizontal">

                <TextView
                    android:textColor="#1A1A1A"
                    android:textSize="17sp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Kategori Makanan" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:textColor="#9B0A0E"
                    android:textSize="10sp"
                    android:layout_marginEnd="11dp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Lihat Menu" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:layout_marginBottom="23dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/cr5bffffff"
                        android:paddingVertical="7dp"
                        android:paddingHorizontal="5dp"
                        android:layout_marginEnd="9dp"
                        android:elevation="10dp"
                        android:orientation="vertical">

                        <TextView
                            android:textColor="#1A1A1A"
                            android:textSize="10sp"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Sedang Populer" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/cr5bffffff"
                        android:paddingVertical="8dp"
                        android:paddingHorizontal="12dp"
                        android:layout_marginEnd="9dp"
                        android:elevation="10dp"
                        android:orientation="vertical">

                        <TextView
                            android:textColor="#1A1A1A"
                            android:textSize="10sp"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Rekomendasi" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/cr5bffffff"
                        android:paddingVertical="7dp"
                        android:paddingHorizontal="24dp"
                        android:layout_marginEnd="9dp"
                        android:elevation="10dp"
                        android:orientation="vertical">

                        <TextView
                            android:textColor="#1A1A1A"
                            android:textSize="10sp"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Sarapan" />
                    </LinearLayout>
                </LinearLayout>
            </HorizontalScrollView>

            <!-- ========== SEDANG POPULER ========== -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="11dp"
                android:layout_marginHorizontal="9dp"
                android:orientation="horizontal">

                <TextView
                    android:textColor="#1A1A1A"
                    android:textSize="17sp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Sedang Populer" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1" />

                <TextView
                    android:textColor="#9B0A0E"
                    android:textSize="10sp"
                    android:layout_marginEnd="11dp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Selengkapnya" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="22dp"
                android:layout_marginHorizontal="9dp"
                android:orientation="horizontal">

                <!-- Sate Ayam -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/cr5bffffff"
                    android:paddingVertical="6dp"
                    android:paddingRight="6dp"
                    android:layout_marginEnd="10dp"
                    android:elevation="10dp"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="154dp"
                        android:layout_height="107dp"
                        android:layout_marginBottom="6dp"
                        android:layout_marginStart="6dp"
                        android:src="@drawable/makanansate"
                        android:scaleType="fitXY" />

                    <TextView
                        android:textColor="#000000"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp"
                        android:layout_marginStart="6dp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Sate Ayam" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/btnTambahSateAyam"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/cr5b9b0a0e"
                            android:paddingVertical="4dp"
                            android:paddingHorizontal="8dp"
                            android:layout_marginEnd="9dp"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true"
                            android:orientation="horizontal">

                            <TextView
                                android:textColor="#FFD700"
                                android:textSize="13sp"
                                android:layout_height="wrap_content"
                                android:layout_width="wrap_content"
                                android:text="Tambah" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Nasi Goreng Telur -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/cr5bffffff"
                    android:paddingVertical="6dp"
                    android:paddingRight="6dp"
                    android:elevation="10dp"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="154dp"
                        android:layout_height="107dp"
                        android:layout_marginBottom="6dp"
                        android:layout_marginStart="6dp"
                        android:src="@drawable/nasigorengdewa"
                        android:scaleType="fitXY" />

                    <TextView
                        android:textColor="#000000"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp"
                        android:layout_marginStart="7dp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Nasi Goreng Telur" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/btnTambahNasiGoreng"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/cr5b9b0a0e"
                            android:paddingVertical="4dp"
                            android:paddingHorizontal="8dp"
                            android:layout_marginEnd="9dp"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true"
                            android:orientation="horizontal">

                            <TextView
                                android:textColor="#FFD700"
                                android:textSize="13sp"
                                android:layout_height="wrap_content"
                                android:layout_width="wrap_content"
                                android:text="Tambah" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ========== REKOMENDASI ========== -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp"
                android:layout_marginHorizontal="10dp"
                android:orientation="horizontal">

                <TextView
                    android:textColor="#1A1A1A"
                    android:textSize="17sp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Rekomendasi" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1" />

                <TextView
                    android:textColor="#9B0A0E"
                    android:textSize="10sp"
                    android:layout_marginEnd="11dp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Selengkapnya" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="22dp"
                android:layout_marginHorizontal="9dp"
                android:orientation="horizontal">

                <!-- Sop Buntut -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/cr5bffffff"
                    android:paddingVertical="6dp"
                    android:paddingRight="6dp"
                    android:layout_marginEnd="10dp"
                    android:elevation="10dp"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="154dp"
                        android:layout_height="107dp"
                        android:layout_marginBottom="6dp"
                        android:layout_marginStart="6dp"
                        android:src="@drawable/sopbuntut"
                        android:scaleType="fitXY" />

                    <TextView
                        android:textColor="#000000"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp"
                        android:layout_marginStart="6dp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Sop Buntut" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/btnTambahSopBuntut"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/cr5b9b0a0e"
                            android:paddingVertical="4dp"
                            android:paddingHorizontal="8dp"
                            android:layout_marginEnd="9dp"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true"
                            android:orientation="horizontal">

                            <TextView
                                android:textColor="#FFD700"
                                android:textSize="13sp"
                                android:layout_height="wrap_content"
                                android:layout_width="wrap_content"
                                android:text="Tambah" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Nasi Goreng Dewa -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/cr5bffffff"
                    android:paddingVertical="6dp"
                    android:paddingRight="6dp"
                    android:elevation="10dp"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="154dp"
                        android:layout_height="107dp"
                        android:layout_marginBottom="6dp"
                        android:layout_marginStart="6dp"
                        android:src="@drawable/nasigorengdewa"
                        android:scaleType="fitXY" />

                    <TextView
                        android:textColor="#000000"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp"
                        android:layout_marginStart="7dp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Nasi Goreng Dewa" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/btnTambahNasiGorengDewa"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/cr5b9b0a0e"
                            android:paddingVertical="4dp"
                            android:paddingHorizontal="8dp"
                            android:layout_marginEnd="9dp"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true"
                            android:orientation="horizontal">

                            <TextView
                                android:textColor="#FFD700"
                                android:textSize="13sp"
                                android:layout_height="wrap_content"
                                android:layout_width="wrap_content"
                                android:text="Tambah" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>