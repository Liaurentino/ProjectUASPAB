<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/rundefined_rl_rl"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        >
        <ImageView
            android:id="@+id/rundefined"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@android:drawable/star_big_on"
            android:scaleType="fitXY"
            />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">
            <ScrollView
                android:id="@+id/rbayv35rtzjq"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingTop="344dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">
                    <LinearLayout
                        android:id="@+id/r0zmyhwd8dht"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/tl30tr30b9b0a0e"
                        android:paddingVertical="17dp"
                        android:orientation="vertical">
                        <LinearLayout
                            android:id="@+id/ruynmgk9i3mo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:layout_marginBottom="2dp"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/rwqzrf7os8"
                                android:textColor="#FFFFFF"
                                android:textSize="26sp"
                                android:layout_height="wrap_content"
                                android:layout_width="wrap_content"
                                android:text="Sign In"
                                />
                        </LinearLayout>
                        <LinearLayout
                            android:id="@+id/rgah0dvortp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/cr4"
                            android:layout_marginBottom="14dp"
                            android:layout_marginHorizontal="16dp"
                            android:orientation="vertical">
                            <LinearLayout
                                android:id="@+id/rb4lv57qtex5"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:paddingBottom="1dp"
                                android:layout_marginBottom="4dp"
                                android:orientation="vertical">
                                <TextView
                                    android:id="@+id/ro191h9awdy"
                                    android:textColor="#FFFFFF"
                                    android:textSize="14sp"
                                    android:layout_height="wrap_content"
                                    android:layout_width="wrap_content"
                                    android:text="Email"
                                    />
                            </LinearLayout>
                            <LinearLayout
                                android:id="@+id/rfwfi9zeeq9m"
                                android:layout_width="match_parent"
                                android:layout_height="40dp"
                                android:background="@drawable/s717171sw1cr5bf2f2f2"
                                android:elevation="10dp"
                                android:orientation="vertical">
                            </LinearLayout>
                        </LinearLayout>
                        <LinearLayout
                            android:id="@+id/ry7o7rwxftz9"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="11dp"
                            android:layout_marginHorizontal="18dp"
                            android:orientation="vertical">
                            <LinearLayout
                                android:id="@+id/r7qwj0totwuk"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingBottom="1dp"
                                android:layout_marginBottom="5dp"
                                android:layout_marginStart="1dp"
                                android:orientation="vertical">
                                <TextView
                                    android:id="@+id/rv6gn5l7v1b"
                                    android:textColor="#FFFFFF"
                                    android:textSize="14sp"
                                    android:layout_height="wrap_content"
                                    android:layout_width="wrap_content"
                                    android:text="Password"
                                    />
                            </LinearLayout>
                            <LinearLayout
                                android:id="@+id/r8oer2oclqtv"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="end"
                                android:background="@drawable/s717171sw1cr5bf2f2f2"
                                android:paddingVertical="11dp"
                                android:paddingRight="20dp"
                                android:elevation="10dp"
                                android:orientation="vertical">
                                <ImageView
                                    android:id="@+id/r78afo2jhjj3"
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:src="@android:drawable/star_big_on"
                                    android:scaleType="fitXY"
                                    />
                            </LinearLayout>
                        </LinearLayout>
                        <LinearLayout
                            android:id="@+id/rif1iway6ex"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingBottom="1dp"
                            android:layout_marginBottom="28dp"
                            android:layout_marginStart="20dp"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/rwvp544ed1km"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:layout_height="wrap_content"
                                android:layout_width="wrap_content"
                                android:text="Forget Password?"
                                />
                        </LinearLayout>
                        <LinearLayout
                            android:id="@+id/ryh616iwhif"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:background="@drawable/cr20bffd700"
                            android:paddingVertical="14dp"
                            android:layout_marginBottom="28dp"
                            android:layout_marginHorizontal="29dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/r14rca3z7hov"
                                android:textColor="#FFFFFF"
                                android:textSize="26sp"
                                android:layout_height="wrap_content"
                                android:layout_width="wrap_content"
                                android:text="Sign In"
                                />
                        </LinearLayout>
                        <LinearLayout
                            android:id="@+id/r03mtva3ayqd3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:layout_marginBottom="19dp"
                            android:orientation="vertical">
                            <LinearLayout
                                android:id="@+id/r25rs2jcbt6s"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">
                                <EditText
                                    android:id="@+id/rzko26oxnhr8"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="Masukkan Nama Anda"
                                    android:textColor="#000000"
                                    android:inputType="textPersonName"
                                    android:padding="12dp"
                                    android:background="@android:drawable/editbox_background_normal"/>
                                <ImageView
                                    android:id="@+id/raa63fl0jv2b"
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:layout_marginEnd="50dp"
                                    android:src="@android:drawable/star_big_on"
                                    android:scaleType="fitXY"
                                    />
                                <ImageView
                                    android:id="@+id/r03dkvm67d108"
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:src="@android:drawable/star_big_on"
                                    android:scaleType="fitXY"
                                    />
                            </LinearLayout>
                        </LinearLayout>
                        <LinearLayout
                            android:id="@+id/r9i72it1f7s"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:orientation="vertical">
                            <LinearLayout
                                android:id="@+id/r4mkmkeh1ivh"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_horizontal"
                                android:orientation="vertical">
                                <TextView
                                    android:id="@+id/rc8owv5bh5ee"
                                    android:textColor="#FFFFFF"
                                    android:textSize="12sp"
                                    android:layout_marginBottom="1dp"
                                    android:layout_height="wrap_content"
                                    android:layout_width="wrap_content"
                                    android:text="Don’t have an account yet?"
                                    />
                                <TextView
                                    android:id="@+id/r99bt2s9f0nm"
                                    android:textColor="#FFD700"
                                    android:textSize="16sp"
                                    android:layout_height="wrap_content"
                                    android:layout_width="wrap_content"
                                    android:text="Sign Up"
                                    />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </ScrollView>
        </LinearLayout>
    </RelativeLayout>
</LinearLayout>