<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/header_merah"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profil"
            android:textColor="#FFD700"
            android:textSize="20sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <ScrollView
        android:id="@+id/rfqvdqo1ut5t"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/rnik22xim5g"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:background="@drawable/cr20bffffff"
                android:paddingTop="21dp"
                android:layout_marginBottom="9dp"
                android:layout_marginHorizontal="21dp"
                android:elevation="30dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/ra8d8ycdzly6"
                    android:textColor="#9B0A0E"
                    android:textSize="20sp"
                    android:layout_marginBottom="45dp"
                    android:layout_marginTop="21dp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Settings"/>

                <LinearLayout
                    android:id="@+id/rkbme4rftzh"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="24dp"
                    android:layout_marginHorizontal="21dp"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/rqk5wetym0k"
                        android:layout_width="55dp"
                        android:layout_height="54dp"
                        android:layout_marginEnd="15dp"
                        android:src="@drawable/nightmodeicon"
                        android:scaleType="fitXY"/>

                    <TextView
                        android:id="@+id/rsxnktphpsn"
                        android:textColor="#1A1A1A"
                        android:textSize="14sp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Aktifkan Dark Mode"/>

                    <LinearLayout
                        android:id="@+id/rvxya8e4o8vd"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"/>

                    <ImageView
                        android:id="@+id/rh67mxs3ykb9"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/switchonofficon"
                        android:scaleType="fitXY"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/rco5mckwlfs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="24dp"
                    android:layout_marginHorizontal="23dp"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/r8tmiioag3vd"
                        android:layout_width="55dp"
                        android:layout_height="54dp"
                        android:layout_marginEnd="15dp"
                        android:src="@drawable/notification"
                        android:scaleType="fitXY"/>

                    <TextView
                        android:id="@+id/rn7hl0hxdrtl"
                        android:textColor="#1A1A1A"
                        android:textSize="14sp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Aktifkan Notifikasi"/>

                    <LinearLayout
                        android:id="@+id/r86pezel0kbf"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"/>

                    <ImageView
                        android:id="@+id/rbp7kc6d06ko"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/switchonofficon"
                        android:scaleType="fitXY"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/rou8cotjgp2q"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="270dp"
                    android:layout_marginHorizontal="23dp"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/rfjtoj3rrec"
                        android:layout_width="55dp"
                        android:layout_height="54dp"
                        android:layout_marginEnd="15dp"
                        android:src="@drawable/servicecenter"
                        android:scaleType="fitXY"/>

                    <TextView
                        android:id="@+id/rlpznwwo55s"
                        android:textColor="#1A1A1A"
                        android:textSize="14sp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Dapatkan Bantuan"/>

                    <LinearLayout
                        android:id="@+id/rl7a263tnux"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"/>

                    <ImageView
                        android:id="@+id/rp77we62resj"
                        android:layout_width="30dp"
                        android:layout_height="36dp"
                        android:src="@drawable/blackarrow"
                        android:scaleType="fitXY"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/rsogk98b11p"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/cr20b9b0a0e"
                    android:paddingVertical="19dp"
                    android:paddingHorizontal="52dp"
                    android:layout_marginBottom="34dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/re30c7jrg36t"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Kembali"/>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>