<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	android:background="#FFFFFF"
	android:orientation="vertical"
	android:layout_width="match_parent"
	android:layout_height="match_parent">


	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="60dp"
		android:background="@drawable/header_merah"
		android:gravity="center">

		<TextView
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="Profil"
			android:textColor="#FFD700"
			android:textSize="20sp"
			android:textStyle="bold"/>

	</LinearLayout>

	<ScrollView
		android:id="@+id/rbbgfiijslsl"
		android:layout_width="match_parent"
		android:layout_height="0dp"
		android:layout_weight="1"
		android:background="#FFFFFF">

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:orientation="vertical">

			<RelativeLayout
				android:id="@+id/r5zk7yzrox2j"
				android:layout_width="match_parent"
				android:layout_height="wrap_content">

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical">

					<LinearLayout
						android:id="@+id/rhsb3xf42jtb"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:orientation="vertical">

						<LinearLayout
							android:id="@+id/rm611l17huv"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:background="@drawable/cr20bffffff"
							android:paddingTop="21dp"
							android:layout_marginBottom="9dp"
							android:layout_marginHorizontal="21dp"
							android:elevation="30dp"
							android:orientation="vertical">

							<LinearLayout
								android:id="@+id/r35hqeg83ntk"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:gravity="center_horizontal"
								android:layout_marginBottom="33dp"
								android:orientation="vertical">

								<TextView
									android:id="@+id/ruzq4rnmm4q8"
									android:textColor="#9B0A0E"
									android:textSize="20sp"
									android:layout_height="wrap_content"
									android:layout_width="wrap_content"
									android:text="Lokasi Restoran"/>
							</LinearLayout>

							<TextView
								android:id="@+id/rdisn6tnjzz"
								android:textColor="#1A1A1A"
								android:textSize="17sp"
								android:layout_marginBottom="21dp"
								android:layout_marginStart="21dp"
								android:layout_height="wrap_content"
								android:layout_width="wrap_content"
								android:text="Cari Restoran"/>

							<EditText
								android:inputType="text"
								android:hint="Masukkan Lokasi Restoran"
								android:id="@+id/rgy97utuzzss"
								android:textColor="#000000"
								android:textSize="16sp"
								android:layout_marginBottom="39dp"
								android:layout_marginHorizontal="21dp"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:background="@drawable/s717171sw1cr5bf2f2f2"
								android:paddingVertical="9dp"
								android:paddingHorizontal="16dp"
								android:elevation="10dp"/>

							<RelativeLayout
								android:id="@+id/rd4uam1he776_rl"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:layout_marginBottom="108dp"
								android:layout_marginHorizontal="23dp">

								<ImageView
									android:id="@+id/rd4uam1he776"
									android:layout_width="match_parent"
									android:layout_height="wrap_content"
									android:src="@drawable/map"
									android:scaleType="fitXY"/>

								<LinearLayout
									android:paddingVertical="104dp"
									android:layout_width="match_parent"
									android:layout_height="wrap_content"
									android:orientation="vertical">

									<LinearLayout
										android:id="@+id/r9o1y5njx0v4"
										android:layout_width="match_parent"
										android:layout_height="wrap_content"
										android:gravity="center_horizontal"
										android:orientation="vertical">

										<LinearLayout
											android:id="@+id/rtejns6je4v"
											android:layout_width="wrap_content"
											android:layout_height="wrap_content"
											android:layout_marginStart="65dp"
											android:background="@drawable/cr8b0f0f14de"
											android:clickable="true"
											android:focusable="true"
											android:orientation="vertical"
											android:paddingHorizontal="9dp"
											android:paddingVertical="6dp">


										</LinearLayout>

										<LinearLayout
											android:id="@+id/rcdvml47osan"
											android:layout_width="wrap_content"
											android:layout_height="wrap_content"
											android:orientation="vertical">

											<ImageView
												android:id="@+id/r4hrhuoi34aq"
												android:layout_width="12dp"
												android:layout_height="6dp"
												android:src="@android:drawable/star_big_on"
												android:scaleType="fitXY"/>

											<ImageView
												android:id="@+id/rvbzzthgpu2q"
												android:layout_width="13dp"
												android:layout_height="6dp"
												android:src="@android:drawable/star_big_on"
												android:scaleType="fitXY"/>
										</LinearLayout>
									</LinearLayout>
								</LinearLayout>
							</RelativeLayout>

							<!-- Tombol Kembali -->
							<LinearLayout
								android:id="@+id/rnvyocou8d0a"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:gravity="center_horizontal"
								android:layout_marginBottom="34dp"
								android:orientation="vertical">

								<LinearLayout
									android:id="@+id/r3ii0ynr89ye"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:background="@drawable/cr20b9b0a0e"
									android:paddingVertical="19dp"
									android:paddingHorizontal="52dp"
									android:clickable="true"
									android:focusable="true"
									android:orientation="vertical">

									<TextView
										android:id="@+id/rvt2ckeaf98"
										android:textColor="#FFFFFF"
										android:textSize="17sp"
										android:layout_height="wrap_content"
										android:layout_width="wrap_content"
										android:text="Kembali"/>
								</LinearLayout>
							</LinearLayout>

						</LinearLayout>
					</LinearLayout>
				</LinearLayout>
			</RelativeLayout>
		</LinearLayout>
	</ScrollView>
</LinearLayout>